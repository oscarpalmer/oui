{
	"author": {
		"name": "Oscar Palmér",
		"url": "https://oscarpalmer.se"
	},
	"dependencies": {
		"@oscarpalmer/atoms": "^0.124",
		"@oscarpalmer/toretto": "^0.34"
	},
	"description": "Styles, components, and utilities for building websites and applications.",
	"devDependencies": {
		"@types/node": "^25",
		"@vitest/coverage-istanbul": "^4",
		"autoprefixer": "^10.4",
		"jsdom": "^27.4",
		"oxfmt": "^0.21",
		"oxlint": "^1.36",
		"postcss-cli": "^11",
		"postcss-input-range": "^6",
		"postcss-scss": "^4",
		"rolldown": "1.0.0-beta.57",
		"sass": "^1.97",
		"stylelint": "^16.26",
		"stylelint-config-standard-scss": "^16",
		"tslib": "^2.8",
		"typescript": "^5.9",
		"vite": "8.0.0-beta.5",
		"vitest": "^4"
	},
	"exports": {
		".": {
			"types": "./types/index.d.ts",
			"default": "./dist/js/index.js"
		},
		"./focus-trap": {
			"types": "./types/focus-trap/standalone.d.ts",
			"default": "./dist/js/focus-trap/standalone.js"
		},
		"./popover": {
			"types": "./types/popover.d.ts",
			"default": "./dist/js/popover.js"
		},
		"./splitter": {
			"types": "./types/splitter.d.ts",
			"default": "./dist/js/splitter.js"
		},
		"./tooltip": {
			"types": "./types/tooltip.d.ts",
			"default": "./dist/js/tooltip.js"
		}
	},
	"files": [
		"dist",
		"src",
		"types"
	],
	"keywords": [
		"css",
		"scss",
		"design",
		"framework",
		"library",
		"style",
		"stylesheet",
		"utility"
	],
	"license": "MIT",
	"module": "dist/js/index.js",
	"name": "@oscarpalmer/oui",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/oscarpalmer/oui.git"
	},
	"scripts": {
		"build": "npm run clean && npm run build:js && npm run build:css",
		"build:css": "npm run build:postcss && npx sass ./postcss:./dist/css --no-source-map",
		"build:postcss": "npx postcss ./src/css/*.scss -d ./postcss -u autoprefixer postcss-input-range --parser postcss-scss",
		"build:js": "npm run clean && npx vite build && npm run rolldown:build && npx tsc",
		"clean": "rm -rf ./dist && rm -rf ./types && rm -f ./tsconfig.tsbuildinfo",
		"rolldown:build": "npx rolldown -c",
		"rolldown:watch": "npx rolldown -c ./rolldown.config.js --watch",
		"test": "npx vitest --coverage",
		"watch:css": "npx sass ./postcss:./dist/css --no-source-map --watch",
		"watch:postcss": "npx postcss ./src/css/*.scss -d ./postcss -u autoprefixer postcss-input-range --parser postcss-scss --watch",
		"watch:js": "npx vite build --watch"
	},
	"type": "module",
	"types": "types/index.d.ts",
	"version": "0.19.0"
}
