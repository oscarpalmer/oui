{
	"name": "@oscarpalmer/oui",
	"version": "0.27.0",
	"description": "Styles, components, and utilities for building websites and applications.",
	"keywords": [
		"css",
		"design",
		"framework",
		"library",
		"scss",
		"style",
		"stylesheet",
		"utility"
	],
	"license": "MIT",
	"author": {
		"name": "Oscar Palmér",
		"url": "https://oscarpalmer.se"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/oscarpalmer/oui.git"
	},
	"files": [
		"dist",
		"src"
	],
	"type": "module",
	"module": "dist/js/index.mjs",
	"types": "dist/js/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/js/index.d.mts",
			"default": "./dist/js/index.mjs"
		},
		"./dialog": {
			"types": "./dist/js/dialog.d.mts",
			"default": "./dist/js/dialog.mjs"
		},
		"./floatable": {
			"types": "./dist/js/floatable/floatable.standalone.d.mts",
			"default": "./dist/js/floatable/floatable.standalone.mjs"
		},
		"./focus-trap": {
			"types": "./dist/js/focus-trap/focus-trap.standalone.d.mts",
			"default": "./dist/js/focus-trap/focus-trap.standalone.mjs"
		},
		"./movable": {
			"types": "./dist/js/movable/movable.standalone.d.mts",
			"default": "./dist/js/movable/movable.standalone.mjs"
		},
		"./popover": {
			"types": "./dist/js/popover.d.mts",
			"default": "./dist/js/popover.mjs"
		},
		"./sortable": {
			"types": "./dist/js/sortable/sortable.standalone.d.mts",
			"default": "./dist/js/sortable/sortable.standalone.mjs"
		},
		"./splitter": {
			"types": "./dist/js/splitter.d.mts",
			"default": "./dist/js/splitter.mjs"
		},
		"./toolbar": {
			"types": "./dist/js/toolbar.d.mts",
			"default": "./dist/js/toolbar.mjs"
		},
		"./tooltip": {
			"types": "./dist/js/tooltip.d.mts",
			"default": "./dist/js/tooltip.mjs"
		}
	},
	"scripts": {
		"build": "vp run clean && vp pack && vp run css:build",
		"clean": "rm -rf ./dist && rm -rf ./postcss",
		"css:build": "vp run postcss:build && vpx sass ./postcss:./dist/css --no-source-map",
		"css:watch": "vpx sass ./postcss:./dist/css --no-source-map --watch",
		"postcss:build": "vpx postcss ./src/css/*.scss -d ./postcss -u autoprefixer postcss-input-range --parser postcss-scss",
		"postcss:watch": "vpx postcss ./src/css/*.scss -d ./postcss -u autoprefixer postcss-input-range --parser postcss-scss --watch",
		"test": "vpx vitest --coverage",
		"tsdown": "vpx tsdown -c ./tsdown.config.ts --watch",
		"watch": "vp run clean && concurrently \"php -S localhost:3000\" \"vp run postcss:watch\" \"vp run css:watch\" \"vp run tsdown\""
	},
	"dependencies": {
		"@oscarpalmer/atoms": "^0.188.1",
		"@oscarpalmer/toretto": "^0.46"
	},
	"devDependencies": {
		"@oxlint/plugins": "^1.72",
		"@vitest/coverage-istanbul": "^4.1",
		"autoprefixer": "^10.5",
		"concurrently": "^10",
		"jsdom": "^29.1",
		"postcss-cli": "^11",
		"postcss-input-range": "^6",
		"postcss-scss": "^4",
		"sass": "^1.101",
		"stylelint": "^17.14",
		"stylelint-config-standard-scss": "^17",
		"tsdown": "^0.22",
		"typescript": "^6",
		"vite": "npm:@voidzero-dev/vite-plus-core@latest",
		"vite-plus": "latest",
		"vitest": "npm:@voidzero-dev/vite-plus-test@latest"
	},
	"packageManager": "npm@11.12.1"
}
